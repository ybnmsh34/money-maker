{
  "name": "filetools",
  "version": "1.0.0",
  "description": "Free online file conversion tools - PDF, Image, Document converters",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npx http-server public -p 3000 -o",
    "build": "echo 'Build complete - static site ready'",
    "deploy:netlify": "npx netlify deploy --prod --dir=public",
    "deploy:vercel": "vercel --prod"
  },
  "keywords": [
    "pdf",
    "image",
    "converter",
    "compress",
    "merge",
    "split",
    "file tools",
    "online tools",
    "free tools"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "canvas": "^3.2.3",
    "mammoth": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "localtunnel": "^2.0.2",
    "puppeteer": "^25.3.0"
  }
}
